# ========================================
# IncidentEnv — Environment Configuration
# ========================================
# Copy this file to .env and fill in your keys.
# NEVER commit .env to git (it's in .gitignore).

# ---------- API Keys ----------
# You need ONE of these (Groq recommended — fast & free):

# Option 1: Groq (recommended, free at https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Option 2: HuggingFace (free at https://huggingface.co/settings/tokens)
HF_TOKEN=your_huggingface_token_here

# Option 3: OpenAI (paid, at https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# ---------- API Configuration ----------
# Groq (default — fastest inference, free tier):
API_BASE_URL=https://api.groq.com/openai/v1
MODEL_NAME=llama-3.3-70b-versatile

# HuggingFace Router (uncomment to use instead):
# API_BASE_URL=https://router.huggingface.co/v1
# MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# OpenAI Direct (uncomment to use instead):
# API_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o

# ---------- Docker ----------
LOCAL_IMAGE_NAME=incident_env:latest
IMAGE_NAME=incident_env:latest
